SCRIPT_PATH=$(dirname $(realpath -s $0))
APP_PATH=$(realpath $SCRIPT_PATH/../..)
USER=$(id -u):$(id -g)

docker run -ti --rm --user $USER -v $APP_PATH:/var/www/html glpi-to-docker composer "$@"
